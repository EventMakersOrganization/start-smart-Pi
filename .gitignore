# --- Build / compiler output (do not commit) ---
dist/
backend/dist/
frontend/dist/
*.tsbuildinfo
**/*.tsbuildinfo

# --- Python bytecode & caches ---
__pycache__/
*.pyc
*.pkl

# --- Local data / logs ---
*.sqlite3
*.log
*.bin
*.map

# Python virtual environments
.venv/
venv/
env/
ai-service/venv/

# Environment secrets
.env
ai-service/.env

# Python (recursive)
**/__pycache__/
*/.py[cod]
*/.pyd
**/*.py[cod]
**/*.pyd

# AI-service caches/artifacts
ai-service/embedding_query_cache/
ai-service/embedding_query_cache/**/*.pkl
ai-service/embedding_query_cache/**/*.json
embedding_query_cache/
**/embedding_query_cache/
**/embedding_query_cache/**
ai-service/logs/
ai-service/response_cache/
ai-service/chroma_db/
# Local backup snapshots (often huge; regenerate from source)
ai-service/backup/

# Backend user uploads (course files — do not commit)
backend/uploads/

# Local-only folders (not tracked)
docs/
scripts/
