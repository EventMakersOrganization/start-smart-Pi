MONGODB_URI=mongodb://localhost:27017/user-management
CHROMA_PERSIST_DIRECTORY=./chroma_db
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
# Fast model for bulk question generation (download with: ollama pull qwen2.5:3b)
# Falls back to OLLAMA_MODEL if not available
OLLAMA_FAST_MODEL=qwen2.5:3b
# Level-test MCQs: Llama 3.2 3B fits ~4GB VRAM; pull: ollama pull llama3.2:3b
OLLAMA_LEVEL_TEST_MODEL=llama3.2:3b
OLLAMA_LEVEL_TEST_MODEL_FALLBACK=qwen2.5:3b