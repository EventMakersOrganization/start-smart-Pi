pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'start-smart/ai-service'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        SONAR_HOST   = credentials('sonar-host-url')
        SONAR_TOKEN  = credentials('sonar-token')
    }

    stages {

        // ---------------------------------------------------------------
        // CI
        // ---------------------------------------------------------------

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('ai-service') {
                    sh 'python -m pip install --upgrade pip'
                    sh 'pip install -r requirements.txt'
                }
            }
        }

        stage('Lint') {
            steps {
                dir('ai-service') {
                    sh 'pip install flake8'
                    sh 'flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics || true'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('ai-service') {
                    sh '''
                        python -m pytest tests/ -k "test_unit" \
                            --junitxml=test-results.xml \
                            --cov=generation --cov=optimization --cov=core --cov=rag \
                            --cov-report=xml:coverage.xml \
                            --cov-report=term-missing \
                            -v --tb=short
                    '''
                }
            }
            post {
                always {
                    junit 'ai-service/test-results.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('ai-service') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            sonar-scanner \
                                -Dsonar.host.url=${SONAR_HOST} \
                                -Dsonar.token=${SONAR_TOKEN}
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ---------------------------------------------------------------
        // CD
        // ---------------------------------------------------------------

        stage('Docker Build') {
            steps {
                dir('ai-service') {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh "echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                dir('ai-service/k8s') {
                    sh "kubectl apply -f deployment.yaml"
                    sh "kubectl apply -f service.yaml"
                    sh "kubectl set image deployment/ai-service ai-service=${DOCKER_IMAGE}:${DOCKER_TAG}"
                    sh "kubectl rollout status deployment/ai-service --timeout=120s"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'AI Service pipeline completed successfully.'
        }
        failure {
            echo 'AI Service pipeline failed.'
        }
    }
}
